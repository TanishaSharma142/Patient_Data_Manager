// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ACCOUNTANT
  SECRETARY
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  role          UserRole
  panicPinHash  String?  // Only for OWNER role
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]
}

model Patient {
  id            String   @id @default(cuid())
  
  // Encrypted fields (stored as base64 encrypted data)
  dateEncrypted      String   // Appointment/treatment date
  patientNameEncrypted String
  phoneEncrypted     String
  addressEncrypted   String
  packageEncrypted   String   // IVF package name
  cashEncrypted      String   // Payment in cash
  bankEncrypted      String   // Payment via bank
  balanceEncrypted   String   // Outstanding amount
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  action        String   // LOGIN, CREATE, UPDATE, DELETE, BACKUP, PANIC_WIPE
  resourceType  String?  // PATIENT, SYSTEM
  resourceId    String?
  ipAddress     String?
  details       String?  // JSON stringified details
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model Backup {
  id            String   @id @default(cuid())
  fileName      String
  encryptedData String   // Base64 encoded encrypted backup
  type          String   // MONTHLY or PANIC_WIPE
  createdAt     DateTime @default(now())
  emailSent     Boolean  @default(false)
  emailSentAt   DateTime?
  notes         String?  // Additional notes

  @@index([type])
  @@index([createdAt])
}
