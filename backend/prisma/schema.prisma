// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ACCOUNTANT
  SECRETARY
}

model User {
  id                  String   @id @default(cuid())
  username            String   @unique
  email               String   @unique
  passwordHash        String
  role                UserRole
  panicPinHash        String?  // Only for OWNER role
  mustChangePassword  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  auditLogs           AuditLog[]
  backupEmails        BackupEmail[]   // Multiple backup emails
}

model BackupEmail {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email             String
  verified          Boolean   @default(false)
  verificationCode  String?
  codeExpiresAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, email])
  @@index([userId])
}

model Patient {
  id                   String    @id @default(cuid())
  date                 DateTime?
  patientNameEncrypted String?
  countryCodeEncrypted String?
  phoneEncrypted       String?
  addressEncrypted     String?
  packageAmount        Decimal?
  cashTotal            Decimal?
  bankAmount           Decimal?
  balanceAmount        Decimal?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  cashEntries          CashEntry[]
  bankEntries          BankEntry[]

  @@index([createdAt])
}

model CashEntry {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  amount      Decimal
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([entryDate])
}

model BankEntry {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  amount      Decimal
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([entryDate])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  action        String
  resourceType  String?
  resourceId    String?
  ipAddress     String?
  details       String?
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model Backup {
  id            String   @id @default(cuid())
  fileName      String
  encryptedData String
  type          String
  createdAt     DateTime @default(now())
  emailSent     Boolean  @default(false)
  emailSentAt   DateTime?
  notes         String?

  @@index([type])
  @@index([createdAt])
}

model SystemState {
  id             String   @id @default(cuid())
  forcedLogoutAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}